rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validConversationData() {
      return request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.title.size() <= 80 &&
          request.resource.data.lastMessagePreview is string &&
          request.resource.data.lastMessagePreview.size() <= 200 &&
          request.resource.data.createdAt is timestamp &&
          request.resource.data.updatedAt is timestamp;
    }

    function validMessageData() {
      return request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 10000 &&
          request.resource.data.isUser is bool &&
          request.resource.data.timestamp is timestamp;
    }

    match /users/{userId}/conversations/{conversationId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validConversationData();
      allow delete: if isOwner(userId);

      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validMessageData();
        allow delete: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
